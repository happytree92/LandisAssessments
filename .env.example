JWT_SECRET=replace-this-with-a-random-secret-at-least-32-chars
DATABASE_URL=./data/assessments.db

# Required for SSO — must be the public-facing base URL of this app (no trailing slash).
# Used to build the OIDC redirect URI: APP_URL/api/auth/sso/callback
# If not set, the redirect URI is derived from the incoming request Host header.
APP_URL=https://assessments.example.com
